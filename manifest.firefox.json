{
  "manifest_version": 3,
  "name": "viewport-leash",
  "version": "0.1.0",
  "description": "Limits the number of visible ChatGPT messages.",
  "browser_specific_settings": {
    "gecko": {
      "id": "viewport-leash@localhost"
    }
  },
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Viewport Leash diagnostics"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["dist/page/stream-coalescer.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["dist/index.js"],
      "run_at": "document_idle"
    }
  ]
}
